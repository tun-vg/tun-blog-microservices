{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "post-route": {
        "ClusterId": "post-cluster",
        "Match": {
          "Path": "post-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "comment-route": {
        "ClusterId": "comment-cluster",
        "Match": {
          "Path": "comment-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "User-route": {
        "ClusterId": "user-cluster",
        "Match": {
          "Path": "user-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "notification-api/{**catch-all}"
        },
        "Transforms": [
          {
            "PathPattern": "{**catch-all}"
          }
        ]
      }
    },
    "Clusters": {
      "post-cluster": {
        "Destinations": {
          "post-destination": {
            "Address": "http://localhost:5270"
          }
        }
      },
      "comment-cluster": {
        "Destinations": {
          "comment-destination": {
            "Address": "http://localhost:5214"
          }
        }
      },
      "user-cluster": {
        "Destinations": {
          "user-destination": {
            "Address": "http://localhost:5087"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification-destination": {
            "Address": "http://localhost:5074"
          }
        }
      }
    }
  }
}
